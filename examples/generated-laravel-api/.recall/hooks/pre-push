#!/bin/sh
# Recall OS pre-push hook.
# Generated by `recall init`. The final regression gate before code leaves your machine: it runs
# `recall doctor` and your configured gates against everything being pushed (catching commits
# made with --no-verify or before the pre-commit hook was active).
# Edit gates in .recall/config.json (preCommitGates), then re-run `recall init --force`.
# Enable once per clone with:
#   git config core.hooksPath .recall/hooks
set -e

recall doctor
